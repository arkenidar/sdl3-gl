{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", ".",
        "-B", "build",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "problemMatcher": [],
      "detail": "Configure the CMake project (Debug, with symbols)"
    },
    {
      "label": "cmake build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build"
      ],
      "dependsOn": "cmake configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Build sdl3-gl"
    },
    {
      "label": "run",
      "type": "shell",
      "command": "${workspaceFolder}/build/sdl3-gl",
      "dependsOn": "cmake build",
      "problemMatcher": [],
      "detail": "Build and run sdl3-gl"
    }
  ]
}
